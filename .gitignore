# Python
*.pyc
__pycache__/

# Environments
.env
*.env
.venv/
venv/

# Generated eval outputs — ignored EXCEPT the small demo data the hosted
# dashboard reads. Committing results.json + the judge/gen caches is what lets
# the public demo show real numbers with no API key (and reproduce offline).
# NOTE: use `dir/*` + negation — git cannot re-include a file under a fully
# excluded directory.
results/*
!results/results.json
cache/*
!cache/*.json
*.csv
# ...but keep hand-authored datasets under data/ (e.g. validation labels)
!data/*.csv

# Downloaded benchmark cache (large; rebuild with scripts/download_benchmarks.py;
# in CI, restore this dir from cache or run the script in a cached step)
data/cached_benchmarks/
