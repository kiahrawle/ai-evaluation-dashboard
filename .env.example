# Primary: the models under test and the LLM judge default to Anthropic/Claude.
ANTHROPIC_API_KEY=sk-ant-...

# Optional: only needed for OpenAI judges/models (e.g. a gpt-4 judge) or if you
# swap the generation backend to OpenAI.
OPENAI_API_KEY=sk-...
# If you route OpenAI through a compatible gateway, also set:
# OPENAI_BASE_URL=https://...
